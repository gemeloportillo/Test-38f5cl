# Dependencias
node_modules/
dist/
plugin/index.js
plugin/index.js.map

# Archivos temporales de InDesign (muy importante)
*.idlk
*.tmp
~*.indd
.DS_Store

# Archivos generados por el plugin (Carpeta de datos)
