plugin/anillo_*.svg
plugin/fix_anillo_*.svg
*.log

# Entorno y Configuración de IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Logs de error de npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Carpeta de build de Webpack (si usas una distinta a plugin/dist)
build/
